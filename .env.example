# Smart Hiring Platform Configuration
# Copy this file to .env and add your actual API keys

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Pinecone Vector Database (Optional)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENV=us-west2-e1

# Model Configuration
LLM_MODEL_NAME=gpt-3.5-turbo
EMBEDDING_MODEL=text-embedding-ada-002

# Data Paths
DATA_DIR=./data
MODELS_DIR=./models

# NLP Settings
TOKENIZER=nltk
STOPWORDS_LANGUAGE=english

# Matching Engine Settings
MIN_MATCH_SCORE=40
MAX_MATCH_SCORE=100
MATCH_SCORE_WEIGHTS=0.3,0.4,0.2,0.1  # content, skill, experience, education

# ML Model Settings
TEST_SIZE=0.2
RANDOM_STATE=42
CV_FOLDS=5
BEST_MODEL_PATH=./models/best_model.pkl

# Clustering Settings
N_CLUSTERS=5
PCA_COMPONENTS=2

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Streamlit Settings
STREAMLIT_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# Logging
LOG_LEVEL=INFO
